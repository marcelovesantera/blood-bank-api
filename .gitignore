## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
bin/
obj/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Rider-specific
.idea/

# VS Code-specific
.github/
.vs/
.vscode/
.history/

# DotCover
*.dotCover

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Logs
*.log

# NuGet Packages
*.nupkg
*.snupkg
packages/
*.symbols.nupkg
project.lock.json
project.fragment.lock.json
artifacts/

# Visual Studio Code workspace history
.vscode/

# Test results
TestResults/
*.vspscc

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Backup & temporary files
*~ 
*.bak
*.tmp
*.temp

# dotenv environment variables
.env
.env.*

# Database files
*.db
*.sqlite

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Local tools
.tools/

# Coverage reports
coverage/
coverage-report/
*.lcov

# Other
node_modules/
